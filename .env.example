# Bouncr environment — copy to .env and fill in. NEVER commit a real .env (it's gitignored).
#
# Sandbox vs live is decided by which secrets are present (Spec §9): with no
# STRIPE_* keys the app runs fully offline (in-memory store, fake Stripe, template
# bouncer) and needs zero setup. Setting STRIPE_SECRET_KEY + STRIPE_WEBHOOK_SECRET
# switches on LIVE mode — and the boot guard (src/config.ts assertLiveBootSecrets)
# then REFUSES to start unless every var marked [LIVE-REQUIRED] below is set and
# not a default/placeholder. Vars below show placeholder values — replace them.

# --- Payments (Stripe) — presence of BOTH switches on LIVE mode -------------
# Stripe secret key. Sandbox: omit (fake gateway). [LIVE-REQUIRED]
STRIPE_SECRET_KEY=sk_live_replace_me
# Stripe webhook signing secret (verifies settlement webhooks). [LIVE-REQUIRED]
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# --- Security secrets — required once live ----------------------------------
# HMAC secret for dashboard session tokens. Sandbox: optional (an ephemeral key is
# minted, so sessions die on restart). [LIVE-REQUIRED] — 32+ random bytes (hex).
BOUNCR_AUTH_SECRET=replace_with_64_hex_chars
# Ed25519 PKCS8 PEM that signs settlement proofs. Sandbox: optional (ephemeral key;
# proofs die on restart). [LIVE-REQUIRED].
BOUNCR_PROOF_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...replace...\n-----END PRIVATE KEY-----"
# Key id published in the proof JWKS. Optional (default "bouncr-1").
BOUNCR_PROOF_KID=bouncr-1
# Demo merchant dashboard password. Sandbox: optional (default "bouncrdemo").
# [LIVE-REQUIRED] and MUST NOT be "bouncrdemo".
BOUNCR_DEMO_MERCHANT_PASSWORD=replace_with_a_strong_password

# --- Data store -------------------------------------------------------------
# Postgres connection string. Sandbox: omit (in-memory store). Required for any
# real/persistent deployment (apply db/schema.sql + db/seed.sql first).
DATABASE_URL=postgres://user:pass@host:5432/bouncr

# --- LLM (the bouncer's persona) --------------------------------------------
# Anthropic key for the real Extractor + Renderer. Sandbox: omit (deterministic
# template negotiator — no persona). Strongly recommended in live for real Vini.
ANTHROPIC_API_KEY=sk-ant-replace_me

# --- Email (settlement / waitlist notifications) ----------------------------
# Resend API key. Sandbox: omit (logs to console instead of sending). Optional.
RESEND_API_KEY=re_replace_me
# From address for outbound email. Optional (default "Bouncr <noreply@thebouncr.com>").
BOUNCR_EMAIL_FROM=Bouncr <noreply@thebouncr.com>

# --- Misc / optional --------------------------------------------------------
# Public base URL for links + the fake gateway. Optional (default http://localhost:8787).
BOUNCR_BASE_URL=https://bouncr.tech
# Platform take-rate as a Connect application fee %, e.g. 20. Optional (default 0).
BOUNCR_APPLICATION_FEE_PERCENT=20
# Demo merchant's programmatic API key (MCP / server-to-server). Optional (a random
# one is generated and logged at boot if unset).
BOUNCR_DEMO_MERCHANT_KEY=
# Require this API key on the merchant API. Optional — when unset the public demo
# endpoints are keyless (and IP rate-limited).
BOUNCR_API_KEY=
# HTTP port for the standalone server (scripts/serve). Optional (default 8787).
PORT=8787
