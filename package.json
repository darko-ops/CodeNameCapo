{
  "name": "@bouncr/policy-engine",
  "version": "0.1.0",
  "description": "Bouncr deterministic pricing policy engine — pure functions, zero runtime deps.",
  "type": "module",
  "main": "./dist/engine.js",
  "types": "./dist/engine.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "bundle:assets": "node scripts/bundle-assets.mjs",
    "prebuild": "node scripts/bundle-assets.mjs",
    "build": "tsc -p tsconfig.json",
    "vercel-build": "npm run build",
    "migrate": "node-pg-migrate up",
    "migrate:create": "node-pg-migrate create --",
    "seed": "node scripts/seed.mjs",
    "scan:plans": "node scripts/scan-plans.mjs",
    "example:merchant": "node scripts/example-merchant-webhook.mjs",
    "test": "vitest run",
    "test:pg": "vitest run src/store/postgres.pg.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "haggle": "tsx src/cli.ts",
    "serve": "tsx src/server.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "@hono/node-server": "^2.0.4",
    "hono": "^4.12.25",
    "postgres": "^3.4.9",
    "stripe": "^22.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "fast-check": "^3.23.1",
    "node-pg-migrate": "^8.0.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
